class Solution {
    public boolean isHappy(int n) {
        if(n==1 || n==7)
        {
            return true;
        }
        else if(n<10)
        {
            return false;
        }
        else
        {
            int temp = n;
            int Hsum = 0;
            while(temp>0)
            {
                int R = temp%10;
                Hsum += R*R;
                temp /= 10;
            }
            return isHappy(Hsum);
        }
        
    }
}
